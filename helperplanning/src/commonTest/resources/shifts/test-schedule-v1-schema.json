{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://rfbpa.rohdef.dk/test-schedule/v1",
  "title": "RFBPA test schedules",

  "type": "object",
  "properties": {
    "in-system": {
      "type": "object",

      "patternProperties": {
        "^[0-9]{4}-W([0-4][0-9]|5[0-3])$": {
          "type": "array",
          "description": "the week for the schedule",

          "items": {
            "type": "object",
            "properties": {
              "day": {
                "type": "string",
                "enum": ["Monday", "Tuesday", "Wednesday", "Thursday", "Friday", "Saturday", "Sunday"]
              },
              "time": {
                "type": "string",
                "pattern": "^([0-1][0-9]|2[0-3]):[0-5][0-9]-([0-1][0-9]|2[0-3]):[0-5][0-9]$"
              },
              "salary-booking": {
                "type": "string",
                "pattern": "^(not booked|helper\\([A-Za-z ]+\\)|unknown\\([A-Za-z ]+\\)|vacancy)$"
              },
              "rfbpa-booking": {
                "type": "string",
                "pattern": "^(not booked|helper\\([A-Za-z ]+\\))$"
              }
            },
            "required": ["day", "time", "salary-booking", "rfbpa-booking"]
          }
        }
      }
    },

    "not-in-system": {
      "type": "object",

      "patternProperties": {
        "^[0-9]{4}-W([0-4][0-9]|5[0-3])$": {
          "type": "array",
          "description": "the week for the schedule",

          "items": {
            "type": "object",
            "properties": {
              "day": {
                "type": "string",
                "enum": ["Monday", "Tuesday", "Wednesday", "Thursday", "Friday", "Saturday", "Sunday"]
              },
              "time": {
                "type": "string",
                "pattern": "^([0-1][0-9]|2[0-3]):[0-5][0-9]-([0-1][0-9]|2[0-3]):[0-5][0-9]$"
              },
              "salary-booking": {
                "type": "string",
                "pattern": "^(not booked|helper\\([A-Za-z ]+\\)|unknown\\([A-Za-z ]+\\)|vacancy)$"
              }
            },
            "required": ["day", "time", "salary-booking"]
          }
        }
      }
    }
  }
}
